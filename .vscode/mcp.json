{
	"servers": {
		"github": {
			"type": "http",
			"url": "https://api.githubcopilot.com/mcp/"
		},
		"copilot-spaces": {
			"type": "http",
			"url": "https://api.githubcopilot.com/mcp/x/copilot_spaces"
		},
		"ado": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@azure-devops/mcp",
				"<orgname>",
				"--authentication",
				"envvar"
			]
		}
	}
}